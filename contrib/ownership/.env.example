# ─────────────────────────────────────────────────────────────────────────────
# OpenTela Ownership Tools – Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# All variables are optional and have sensible defaults. The scripts will
# fall back to devnet settings when nothing is configured.
# ─────────────────────────────────────────────────────────────────────────────

# ── Solana Cluster ──────────────────────────────────────────────────────────
# Which Solana cluster to connect to.
# Accepted values: mainnet-beta, devnet, testnet, localnet, or a full URL.
# Default: devnet
SOLANA_CLUSTER=devnet

# Custom RPC endpoint (overrides SOLANA_CLUSTER when set).
# Examples:
#   https://api.devnet.solana.com
#   https://api.mainnet-beta.solana.com
#   http://127.0.0.1:8899
SOLANA_RPC_URL=

# ── Keypair / Wallet ───────────────────────────────────────────────────────
# Path to a Solana CLI keypair JSON file used as the fee-payer and authority
# for token operations.  This is the same format produced by:
#   solana-keygen new --outfile ~/.config/solana/id.json
#   otela wallet export --file ./my-keypair.json
#
# Default: ~/.config/solana/id.json
KEYPAIR_PATH=

# Alternatively, supply the base58-encoded private key directly (the format
# used by Phantom's "Export Private Key" flow).  KEYPAIR_PATH takes
# precedence when both are set.
# ⚠  Never commit this value to source control!
PRIVATE_KEY_BASE58=

# ── Token Configuration ────────────────────────────────────────────────────
# Mint address of the OpenTela ownership token.  Leave empty when creating
# a new token; the create-token script will print the address after
# deployment.  Set this once the token exists so that other scripts know
# which mint to interact with.
TOKEN_MINT=

# Human-readable token metadata (used by create-token).
TOKEN_NAME=OpenTela
TOKEN_SYMBOL=OTELA
TOKEN_DECIMALS=9
TOKEN_URI=https://arweave.net/opentela-token-metadata.json

# Initial supply to mint right after token creation (in whole tokens, not
# raw amounts).  Set to 0 to skip the initial mint.
TOKEN_INITIAL_SUPPLY=0

# ── Anchor / On-chain Program ──────────────────────────────────────────────
# Program ID of the deployed Anchor token_minter program (from tokens/).
# Only needed if you use the Anchor-based minting path instead of the
# direct SPL path.
ANCHOR_PROGRAM_ID=

# ── Ownership Verification ─────────────────────────────────────────────────
# Minimum token balance (in whole tokens) required for a wallet to be
# considered a valid OpenTela provider.
OWNERSHIP_MIN_BALANCE=1

# ── Logging ────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose / debug output from all scripts.
DEBUG=false
