#!/bin/bash
#SBATCH --job-name={{ job_name }}
{% if account %}
#SBATCH --account={{ account }}
{% endif %}
{% if partition %}
#SBATCH --partition={{ partition }}
{% endif %}
#SBATCH --time={{ time }}
#SBATCH --gpus-per-node={{ gpus }}
#SBATCH --nodes={{ nodes }}
{% if cpus_per_task %}
#SBATCH --cpus-per-task={{ cpus_per_task }}
{% endif %}
{% for line in extra_sbatch %}
{{ line }}
{% endfor %}
#SBATCH --output={{ log_dir }}/opentela_%j.out
#SBATCH --error={{ log_dir }}/opentela_%j.err

set -euo pipefail

export SERVICE_PORT={{ service_port }}
export HF_HOME="{{ hf_cache }}"

OTELA_BINARY="{{ binary_path }}"
OTELA_CONFIG="{{ worker_config }}"
SIF="{{ sif_path }}"

MASTER_ADDR=$(scontrol show hostnames "$SLURM_JOB_NODELIST" | head -n1)
MASTER_PORT=29500

echo "=== Multi-node setup ==="
echo "Nodes: $SLURM_JOB_NUM_NODES ($SLURM_JOB_NODELIST)"
echo "Master: $MASTER_ADDR:$MASTER_PORT"

{% for mod in modules %}
module load {{ mod }}
{% endfor %}

mkdir -p "$HF_HOME"

{% for key, val in nccl_env.items() %}
export {{ key }}="{{ val }}"
{% endfor %}

TUNNEL_PID=""
PCHAIN=""
{% if proxychains is defined and proxychains.enabled %}
# --- Proxychains: SSH SOCKS tunnel for compute nodes without internet ---
export SSH_KEY="{{ proxychains.ssh_key }}"
export PATH="$HOME/.local/bin:$PATH"
SOCKS_PORT={{ proxychains.socks_port }}

PROXYCHAINS_CONF="$HOME/opentela/proxychains_${SLURM_JOB_ID}.conf"
cat > "$PROXYCHAINS_CONF" << EOF
strict_chain
quiet_mode
proxy_dns
[ProxyList]
socks5 127.0.0.1 $SOCKS_PORT
EOF

echo "Starting SSH SOCKS tunnel to {{ proxychains.proxy_target }}..."
ssh -i "$SSH_KEY" \
    -o StrictHostKeyChecking=no \
    -o ExitOnForwardFailure=yes \
    -o ServerAliveInterval=60 \
    -N -D "127.0.0.1:$SOCKS_PORT" \
    {{ proxychains.proxy_target }} &
TUNNEL_PID=$!
sleep 3
if ! kill -0 "$TUNNEL_PID" 2>/dev/null; then
    echo "ERROR: SSH SOCKS tunnel failed to start"
    exit 1
fi
echo "Tunnel established (PID=$TUNNEL_PID)"

export HTTPS_PROXY="socks5h://127.0.0.1:$SOCKS_PORT"
export HTTP_PROXY="socks5h://127.0.0.1:$SOCKS_PORT"
export ALL_PROXY="socks5h://127.0.0.1:$SOCKS_PORT"
PCHAIN="proxychains4 -q -f $PROXYCHAINS_CONF"
{% endif %}

{% if pull_if_missing %}
if [ ! -f "$SIF" ]; then
    echo "Pulling container (one-time)..."
    mkdir -p "$(dirname "$SIF")"
    $PCHAIN apptainer pull "$SIF" docker://{{ container_image }}
fi
{% endif %}

# Create per-node launcher script
LAUNCHER="$HOME/opentela/node_launcher_${SLURM_JOB_ID}.sh"
cat > "$LAUNCHER" << 'LAUNCHER_EOF'
#!/bin/bash
set -euo pipefail
NODE_RANK=$SLURM_NODEID
echo "[Node $NODE_RANK/$(hostname)] Starting backend..."

apptainer exec \
{% for flag in apptainer_flags %}
    {{ flag }} \
{% endfor %}
{% for mount in container_mounts %}
    --bind "{{ mount }}" \
{% endfor %}
    --bind "$HF_HOME:$HF_HOME" \
    --env HF_HOME="$HF_HOME" \
    --env SERVICE_PORT="$SERVICE_PORT" \
{% for key, val in container_env.items() %}
    --env {{ key }}="{{ val }}" \
{% endfor %}
    "$SIF" \
    $USER_CMD
LAUNCHER_EOF
chmod +x "$LAUNCHER"

# Pass user command via environment
export USER_CMD="{{ user_cmd }}"
export SIF

echo "Launching across {{ nodes }} nodes..."
srun --ntasks-per-node=1 --nodes={{ nodes }} \
    bash "$LAUNCHER" &
BACKEND_PID=$!

echo "Waiting for backend to be ready on $MASTER_ADDR:$SERVICE_PORT..."
for i in $(seq 1 {{ startup_timeout }}); do
    if curl -sf "http://${MASTER_ADDR}:${SERVICE_PORT}/health" > /dev/null 2>&1; then
        echo "Backend is ready after ${i}s"
        break
    fi
    if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
        echo "ERROR: backend process died"
        rm -f "$LAUNCHER"
        exit 1
    fi
    sleep 1
done

if ! curl -sf "http://${MASTER_ADDR}:${SERVICE_PORT}/health" > /dev/null 2>&1; then
    echo "ERROR: backend failed to start within {{ startup_timeout }}s"
    kill "$BACKEND_PID" 2>/dev/null || true
    rm -f "$LAUNCHER"
    exit 1
fi

echo "Starting OpenTela worker..."
"$OTELA_BINARY" start --config "$OTELA_CONFIG" &
OTELA_PID=$!

echo "OpenTela worker started (PID=$OTELA_PID)"
echo "Backend running (PID=$BACKEND_PID)"
echo "Job is running on nodes: $SLURM_JOB_NODELIST"

wait -n "$BACKEND_PID" "$OTELA_PID" 2>/dev/null
EXIT_CODE=$?

echo "A process exited with code $EXIT_CODE, shutting down..."
kill "$BACKEND_PID" "$OTELA_PID" 2>/dev/null || true
[ -n "$TUNNEL_PID" ] && kill "$TUNNEL_PID" 2>/dev/null || true
rm -f "$LAUNCHER"
wait
exit $EXIT_CODE
